{
  "name": "serverest-cypress-qa-challenge",
  "version": "1.0.0",
  "private": true,
  "description": "Cypress E2E and API test suite for ServeRest",
  "scripts": {
    "cy:open": "cypress open",
    "test:e2e": "cypress run --spec \"cypress/e2e/frontend/**/*.cy.js\"",
    "test:api": "cypress run --spec \"cypress/e2e/api/**/*.cy.js\"",
    "test:all": "cypress run",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify": "npm run lint && npm run format:check && npm run test:all"
  },
  "engines": {
    "node": ">=24.0.0 <25"
  },
  "packageManager": "npm@11.10.1",
  "overrides": {
    "diff": "8.0.4",
    "serialize-javascript": "7.0.7",
    "uuid": "11.1.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "cypress": "15.19.0",
    "cypress-mochawesome-reporter": "4.0.2",
    "eslint": "10.7.0",
    "eslint-plugin-cypress": "6.4.3",
    "globals": "17.7.0",
    "prettier": "3.9.6"
  }
}
